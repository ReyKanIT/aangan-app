{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://okzmeuhxodzkbdilvkyu.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_w_bBTY5Rj-6rtPO1sssUig_KsMsidFD"
      }
    },
    "preview-ios-sim": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://okzmeuhxodzkbdilvkyu.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_w_bBTY5Rj-6rtPO1sssUig_KsMsidFD"
      }
    },
    "production": {
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "autoIncrement": true,
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://okzmeuhxodzkbdilvkyu.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_w_bBTY5Rj-6rtPO1sssUig_KsMsidFD"
      }
    },
    "production-apk": {
      "android": {
        "autoIncrement": true,
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://okzmeuhxodzkbdilvkyu.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_w_bBTY5Rj-6rtPO1sssUig_KsMsidFD"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "//": "Fill AFTER creating the app in App Store Connect (see ASC_NEXT_STEPS_2026-05-06.md). Or set EXPO_APPLE_ID / ASC_APP_ID / APPLE_TEAM_ID env vars and EAS picks them up automatically.",
        "appleId": "$EXPO_APPLE_ID",
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      }
    }
  }
}
